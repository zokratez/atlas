{
  "name": "atlas-workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "scout": "node dist/workers/scout.js",
    "scout:pulse": "node dist/workers/scout-pulse.js",
    "lens": "node dist/workers/lens.js",
    "lens:weekly": "node dist/workers/lens.js --cadence weekly",
    "lens:monthly": "node dist/workers/lens.js --cadence monthly",
    "lens:quarterly": "node dist/workers/lens.js --cadence quarterly",
    "quill": "node dist/workers/quill.js",
    "producer": "node dist/workers/producer.js",
    "results:autopilot": "node dist/workers/results-autopilot.js",
    "results:instagram": "node dist/workers/ig-puller.js",
    "video:dissect": "node dist/workers/video-dissect.js",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.60.0",
    "@supabase/supabase-js": "^2.52.0",
    "dotenv": "^17.2.0",
    "pdf-parse": "^2.4.5",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "typescript": "^5.8.3"
  }
}
